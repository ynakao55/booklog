<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <title><%= content_for?(:title) ? yield(:title) : "Booklog" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom mb-4">
      <div class="container">
        <a class="navbar-brand fw-bold" href="<%= root_path %>">Booklog</a>
      </div>
    </nav>

    <main class="container" style="max-width: 960px;">
      <!-- ページタイトル -->
      <header class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><%= content_for?(:title) ? yield(:title) : "Books" %></h1>
      </header>

      <!-- フラッシュ -->
      <% flash.each do |type, msg| %>
        <div class="alert alert-<%= type == "notice" ? "success" : "warning" %>"><%= msg %></div>
      <% end %>

      <!-- ツールバー（[New book] Filter…） -->
      <% if content_for?(:toolbar) %>
        <section class="card shadow-lg border mb-3">
          <div class="card-body d-flex justify-content-between align-items-center">
            <%= yield :toolbar %>
          </div>
        </section>
      <% end %>

      <!-- メイン（一覧など） -->
      <section class="card shadow-sm border-0">
        <div class="card-body">
          <%= yield %>
        </div>
      </section>
    </main>
  </body>
</html>
